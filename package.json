{
	"name": "@pikaboo/t2-design-system",
	"version": "0.1.0",
	"description": "Pikaboo design system tokens, themes, and React components.",
	"type": "module",
	"private": false,
	"publishConfig": {
		"access": "restricted",
		"registry": "https://timbuk2-539247467239.d.codeartifact.eu-west-1.amazonaws.com/npm/npm/"
	},
	"engines": {
		"node": ">=24.0.0",
		"npm": ">=10.9.0"
	},
	"sideEffects": [
		"**/*.css"
	],
	"files": [
		"dist"
	],
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs"
		},
		"./auth": {
			"types": "./dist/auth.d.ts",
			"import": "./dist/auth.js",
			"require": "./dist/auth.cjs"
		},
		"./auth-core": {
			"types": "./dist/auth-core.d.ts",
			"import": "./dist/auth-core.js",
			"require": "./dist/auth-core.cjs"
		},
		"./auth-jsx": {
			"types": "./dist/auth-jsx.d.ts",
			"import": "./dist/auth-jsx.js",
			"require": "./dist/auth-jsx.cjs"
		},
		"./auth-jsx/jsx-runtime": {
			"types": "./dist/auth-jsx/jsx-runtime.d.ts",
			"import": "./dist/auth-jsx/jsx-runtime.js",
			"require": "./dist/auth-jsx/jsx-runtime.cjs"
		},
		"./react/auth": {
			"types": "./dist/react/auth.d.ts",
			"import": "./dist/react/auth.js",
			"require": "./dist/react/auth.cjs"
		},
		"./react/report": {
			"types": "./dist/react/report.d.ts",
			"import": "./dist/react/report.js",
			"require": "./dist/react/report.cjs"
		},
		"./report": {
			"types": "./dist/report.d.ts",
			"import": "./dist/report.js",
			"require": "./dist/report.cjs"
		},
		"./report-core": {
			"types": "./dist/report-core.d.ts",
			"import": "./dist/report-core.js",
			"require": "./dist/report-core.cjs"
		},
		"./report-jsx": {
			"types": "./dist/report-jsx.d.ts",
			"import": "./dist/report-jsx.js",
			"require": "./dist/report-jsx.cjs"
		},
		"./report-jsx/jsx-runtime": {
			"types": "./dist/report-jsx/jsx-runtime.d.ts",
			"import": "./dist/report-jsx/jsx-runtime.js",
			"require": "./dist/report-jsx/jsx-runtime.cjs"
		},
		"./tailwind": {
			"types": "./dist/tailwind.d.ts",
			"import": "./dist/tailwind.js",
			"require": "./dist/tailwind.cjs"
		},
		"./theme": {
			"types": "./dist/theme.d.ts",
			"import": "./dist/theme.js",
			"require": "./dist/theme.cjs"
		},
		"./styles.css": "./dist/styles.css"
	},
	"lint-staged": {
		"*": "biome check --fix --no-errors-on-unmatched"
	},
	"scripts": {
		"prepare": "husky",
		"dev": "storybook dev -p 2050 --host 127.0.0.1 --no-open",
		"storybook": "storybook dev -p 2050 --host 127.0.0.1 --no-open",
		"build-storybook": "storybook build",
		"build": "vite build",
		"build:package": "npm run type-check && npm run check && npm test && npm run build",
		"prepublishOnly": "npm run build:package",
		"pack:check": "npm_config_cache=/private/tmp/pds-npm-cache npm pack --dry-run",
		"artifact:login": "aws codeartifact login --tool npm --domain timbuk2 --domain-owner 539247467239 --repository npm --region eu-west-1",
		"publish:artifact:dry-run": "npm_config_cache=/private/tmp/pds-npm-cache npm publish --dry-run --access restricted",
		"publish:artifact": "npm_config_cache=/private/tmp/pds-npm-cache npm publish --access restricted",
		"lint": "biome lint --error-on-warnings",
		"format": "biome format --write",
		"check": "biome check",
		"check:fix": "biome check --write",
		"type-check": "tsc --noEmit",
		"test": "vitest run",
		"test:unit": "vitest --project unit run",
		"test:storybook": "vitest --project storybook run",
		"init-timbuk2-npm": "sh -c 'AWS_PROFILE=\"${1:?Usage: npm run init-timbuk2-npm <AWS_PROFILE>}\" exec aws codeartifact login --tool npm --domain timbuk2 --domain-owner 539247467239 --repository npm --region eu-west-1' init-timbuk2-npm"
	},
	"peerDependencies": {
		"react": "^18.3.0 || ^19.0.0",
		"react-dom": "^18.3.0 || ^19.0.0"
	},
	"devDependencies": {
		"@biomejs/biome": "2.3.13",
		"@storybook/addon-a11y": "^10.4.0",
		"@storybook/addon-docs": "^10.4.0",
		"@storybook/addon-vitest": "^10.4.0",
		"@storybook/react-vite": "^10.4.0",
		"@types/node": "^25.8.0",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^6.0.2",
		"@vitest/browser": "^4.1.6",
		"@vitest/browser-playwright": "^4.1.6",
		"husky": "^9.1.7",
		"jsdom": "^29.1.1",
		"lint-staged": "^17.0.5",
		"playwright": "^1.60.0",
		"react": "^19.2.6",
		"react-dom": "^19.2.6",
		"storybook": "^10.4.0",
		"typescript": "^6.0.3",
		"vite": "^8.0.13",
		"vite-plugin-dts": "^5.0.0",
		"vitest": "^4.1.6"
	}
}
