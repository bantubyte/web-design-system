{
	"extends": "./tsconfig.json",
	"compilerOptions": {
		"noEmit": false,
		"declaration": true,
		"emitDeclarationOnly": true,
		"rootDir": "src",
		"outDir": "dist"
	},
	"include": ["src/svelte/**/*"],
	"exclude": [
		"src/**/*.test.ts",
		"src/**/*.test.tsx",
		"src/**/*.stories.tsx",
		"dist",
		"node_modules"
	]
}
